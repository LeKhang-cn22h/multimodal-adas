# MULTIMODAL-ADAS Environment Variables
# Copy file này thành .env và điền giá trị thật

# IP máy mạnh chạy aggregator (dùng cho driver/lane/vehicle/camera service)
GATEWAY_HOST=192.168.1.100

# Driver service config
EAR_THRESHOLD=0.22
DROWSY_FRAMES=60
CAMERA_ID=0

# Lane service config
LANE_HOST=localhost

# Vehicle service config
VEHICLE_HOST=localhost

# Camera service config
CAMERA_HOST=localhost
